# ============================================================================
# TICKET BOOKING PLATFORM - ENVIRONMENT CONFIGURATION
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================================

# ---- Server ----
ENVIRONMENT=development
DEBUG=true
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=INFO

# ---- Database (Postgres via Docker Compose) ----
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ticket_booking
DATABASE_ECHO=false

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Security ----
# Generate a real one with: openssl rand -hex 32
SECRET_KEY=dev-only-change-me-1234567890abcdef1234567890abcdef
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24

# ---- CORS ----
CORS_ORIGINS=["http://localhost:3000"]

# ---- Email (SendGrid) — leave blank to use console/dev email backend ----
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@ticketbooking.pk
EMAIL_BACKEND=console
# EMAIL_BACKEND options: console (prints to logs, default for local dev), sendgrid

# ---- Payment Gateways ----
# Leave PAYMENT_PROVIDER=mock for local dev. Swap to jazzcash/easypaisa when ready.
PAYMENT_PROVIDER=mock

JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_RETURN_URL=http://localhost:8000/api/v1/payments/jazzcash/callback

EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
EASYPAISA_RETURN_URL=http://localhost:8000/api/v1/payments/easypaisa/callback

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
